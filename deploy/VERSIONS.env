# Pinned third-party image versions
# Update these when upgrading dependencies. Never use :latest in production.
#
# To upgrade: change the version here, then run:
#   docker compose --env-file deploy/VERSIONS.env pull
#
# Zitadel migration:
#   - Greenfield (no existing events): jump straight to v4.x (PG 18 support).
#   - Existing v2 data: stage v2 -> v3.4.9 -> v4.14.0; v3 needs PG 17 because
#     v3 migration `34_add_cache_schema` uses UNLOGGED partitioned tables
#     which PG 18 removed.
#
# Postgres pg16 -> pg18 is destructive (cluster format change):
#   - dev/test: drop volumes (zitadel-db-data, fleet-pg-data) and re-init
#   - prod: pg_upgrade against existing data dir BEFORE pulling new tag
# Plan Phase F mandates a staging dry-run + DB backup before bumping in prod.

TIMESCALEDB_VERSION=2.28.1-pg18
GRAFANA_VERSION=13.0.2
NODE_RED_VERSION=5.0.0-24
ZITADEL_VERSION=v4.15.3
ZITADEL_POSTGRES_VERSION=18.3-alpine3.23

# Staged-upgrade intermediates. Used by `deploy.sh migrate` when the running
# Zitadel is v2 and the target is v4 — v3 migration `34_add_cache_schema`
# uses UNLOGGED partitioned tables which PG 18 removed, so the migration
# stops at v3.4.9 on PG 17 first, then progresses to v4 on PG 18.
ZITADEL_STAGE_VERSION=v3.4.9
ZITADEL_STAGE_POSTGRES_VERSION=17-alpine
MAILCATCHER_VERSION=20260426
MDNS_REPEATER_VERSION=latest

# Fleet Manager
NODE_VERSION=24-alpine
FM_VERSION=latest
REDIS_VERSION=7.4.2-alpine

# Traefik reverse proxy (used with --routing traefik or --shared)
TRAEFIK_VERSION=v3.7.5

# Dozzle log viewer (optional logging stack)
DOZZLE_VERSION=v10.6.6
