# Fleet Management — Public / Community Deploy
#
# Pre-configured for deploy-public.sh one-click community deployment.
# Weak passwords, auto hostname. Suitable for evaluation and testing.

# ─── Project name ──────────────────────────────────────────
COMPOSE_PROJECT_NAME=fleet-public

# ─── TimescaleDB ───────────────────────────────────────────
# Empty = generator fills + persists to deploy/state/.env.
POSTGRES_PASSWORD=

# ─── Zitadel ──────────────────────────────────────────────
ZITADEL_MASTERKEY=
ZITADEL_POSTGRES_PASSWORD=
ZITADEL_DB_USER_PASSWORD=
ZITADEL_ADMIN_PASSWORD=
ZITADEL_HOSTNAME=auto
ZITADEL_EXTERNALPORT=9090
# Host-only Zitadel API bind for bootstrap/health scripts.
ZITADEL_API_HOST_BIND=127.0.0.1
ZITADEL_API_HOST_PORT=8080
# Set true when FM is reachable over HTTPS (deploy-public.sh sets this on --ssl).
ZITADEL_EXTERNALSECURE=false

# ─── Fleet Manager ────────────────────────────────────────
FM_VERSION=latest
FLEET_MANAGER_PORT=7011
# Trust forwarded device cert headers only from Traefik/container proxy peers.
FM_DEVICE_INGRESS_TRUSTED_PROXY_CIDRS=127.0.0.1/32,172.16.0.0/12
# Waiting-room org for gate-less devices; empty = code default.
FM_DEVICE_INGRESS_DEFAULT_ORGANIZATION_ID=
# Empty = generator fills + persists. Never set literal values here.
FM_SECRET_ENCRYPTION_KEY=
FM_SECRET_KDF_SALT=
JWT_SECRET=

# ─── Zitadel Bootstrap (OIDC setup) ─────────────────────
# These configure the Fleet Manager project and admin user created in Zitadel.
# Change before first deploy — changing after bootstrap has no effect
# (delete deploy/state/ and re-bootstrap to apply changes).
ZITADEL_PROJECT_NAME=fleet-manager
# Default/root Zitadel org.
ZITADEL_DEFAULT_ORG_NAME=zitadel
# Self-hosted default: the owner org is both provider-support/instance-owner
# and the FM tenant org. SaaS deployments keep this separate as `shelly`.
FM_PLATFORM_ORG_NAME=fleet
# Tenant org where the Fleet Manager OAuth project is created.
FM_CLIENT_ORG_NAME=fleet
# Login V2 — login-client PAT expiry (auto-created at FIRSTINSTANCE init)
LOGIN_CLIENT_PAT_EXPIRATION=2099-01-01T00:00:00Z
# Public scheme used to build V2 login URLs at instance level (https when SSL terminates above us)
ZITADEL_PUBLIC_SCHEME=https
# Brute-force caps (Zitadel default of 0 = unlimited).
ZITADEL_LOCKOUT_MAX_PASSWORD=10
ZITADEL_LOCKOUT_MAX_OTP=5
ZITADEL_LOCKOUT_SHOW_FAILURES=true
# 0=NOT_ALLOWED, 1=ALLOWED (passkeys).
ZITADEL_PASSWORDLESS_TYPE=1
# Force MFA on every login (applied at every deploy).
ZITADEL_FORCE_MFA=false
# Surface upstream OIDC errors in logs (helpful in non-prod, noisy in prod).
ZITADEL_DEBUG_OIDC_PARENT_ERROR=false
# Zitadel DB backup: dump cadence (s), retention (days).
ZITADEL_BACKUP_INTERVAL=86400
FM_BACKUP_RETAIN_DAYS=7
# Inbound SCIM provisioning toggle (Zitadel SCIM v2 endpoint at /scim/v2/).
FM_ZITADEL_SCIM_ENABLED=false
FM_RUNTIME_KEYS_CACHE_TTL_MS=30000
# Traefik per-IP rate limit on /oauth/v2/* (token, authorize, introspect).
FM_LOGIN_RATE_LIMIT_AVERAGE=10
FM_LOGIN_RATE_LIMIT_BURST=30
FM_LOGIN_RATE_LIMIT_PERIOD=1m
FM_LOCAL_CA_NAME=Fleet Manager Root CA
# Login page branding — empty fields keep Zitadel defaults.
FM_BRAND_PRIMARY_COLOR=#4495d1
FM_BRAND_WARN_COLOR=#b91c1c
FM_BRAND_BACKGROUND_COLOR=#0a1422
FM_BRAND_FONT_COLOR=#f0f2f4
FM_BRAND_PRIMARY_COLOR_DARK=#4495d1
FM_BRAND_WARN_COLOR_DARK=#b91c1c
FM_BRAND_BACKGROUND_COLOR_DARK=#0a1422
FM_BRAND_FONT_COLOR_DARK=#f0f2f4
FM_BRAND_HIDE_LOGIN_NAME_SUFFIX=true
FM_BRAND_DISABLE_WATERMARK=true
# External IdPs — set per-tenant, all empty = no IdPs registered.
FM_IDP_GOOGLE_CLIENT_ID=
FM_IDP_GOOGLE_CLIENT_SECRET=
FM_IDP_GITHUB_CLIENT_ID=
FM_IDP_GITHUB_CLIENT_SECRET=
FM_IDP_AZURE_TENANT_ID=
FM_IDP_AZURE_CLIENT_ID=
FM_IDP_AZURE_CLIENT_SECRET=
FM_IDP_OIDC_ISSUER=
FM_IDP_OIDC_CLIENT_ID=
FM_IDP_OIDC_CLIENT_SECRET=
FM_IDP_JWT_ISSUER=
FM_IDP_JWT_KEYS_ENDPOINT=
# SCIM inbound provisioning (HRIS sync). PAT lands in state/zitadel.env.
FM_SCIM_ENABLED=false
# Logo upload paths (PNG/SVG); empty = keep Zitadel logo.
FM_BRAND_LOGO_PATH=
FM_BRAND_LOGO_DARK_PATH=
# Favicon (light + dark) — empty = keep Zitadel default.
FM_BRAND_ICON_PATH=
FM_BRAND_ICON_DARK_PATH=
# TTF font for login screens — empty = inherit instance default.
FM_BRAND_FONT_PATH=
# Theme mode: THEME_MODE_AUTO | THEME_MODE_LIGHT | THEME_MODE_DARK (FM is dark).
FM_BRAND_THEME_MODE=THEME_MODE_DARK
# Privacy / legal links shown on login + console (all optional).
FM_PRIVACY_TOS_LINK=
FM_PRIVACY_PRIVACY_LINK=
FM_PRIVACY_HELP_LINK=
FM_PRIVACY_SUPPORT_EMAIL=
FM_PRIVACY_DOCS_LINK=
FM_PRIVACY_CUSTOM_LINK=
FM_PRIVACY_CUSTOM_LINK_TEXT=
# Zitadel identity SMTP is off by default. Set real values to send
# identity emails; FM notification email uses FM_NOTIFICATION_SMTP_*.
ZITADEL_SMTP_TLS=true
ZITADEL_SMTP_HOST=
ZITADEL_SMTP_USER=
ZITADEL_SMTP_PASSWORD=
ZITADEL_SMTP_FROM=
ZITADEL_SMTP_FROM_NAME=Shelly Fleet
ZITADEL_HTTP_TIMEOUT_MS=5000
ZITADEL_PAT_DEFAULT_EXPIRATION_DAYS=365
ZITADEL_LIST_PAGE_SIZE=1000
FM_ENDPOINT_SECRET_CAS_RETRIES=5
FM_MDNS_ENABLED=false
FM_REQUIRE_ALL_PLUGINS=false
FM_EXIT_ON_FATAL_ERRORS=true
FM_EMDATA_TICK_INTERVAL_MS=1000
FM_EMDATA_SYNC_THRESHOLD_MS=540000
FM_EMDATA_GRACE_PERIOD_MS=300000
FM_HTTP_BREAKER_THRESHOLD=5
FM_HTTP_BREAKER_WINDOW_MS=30000
FM_HTTP_BREAKER_COOLDOWN_MS=60000
FM_HTTP_BREAKER_MAX_HOSTS=1024
FM_ADMIN_USER=fm-admin
# Empty = generator fills + persists on first public install.
FM_ADMIN_PASSWORD=
FM_ADMIN_EMAIL=admin@fleet.local
FM_PLATFORM_ADMIN_USER=fm-platform-admin
FM_PLATFORM_ADMIN_EMAIL=platform-admin@shelly.local
# Empty = generator fills + persists on first public install.
FM_PLATFORM_ADMIN_PASSWORD=
FM_PLATFORM_ADMIN_ROLE=IAM_OWNER
FM_PLATFORM_SUPPORT_READ_ROLE=IAM_OWNER_VIEWER
FM_ZITADEL_SERVICE_INSTANCE_ROLE=IAM_OWNER

# ─── Frontend Debug/Perf (runtime-injected) ─────────────
FM_DEBUG_DEFAULT=false
FM_PERF_TRACING=false
FM_OBSERVABILITY=true
# Bearer token for /metrics scrapers. Empty = logged-in session only.
FM_OBS_AUTH_TOKEN=
# Hard cap on Integration.Endpoint.Test (verify + send). Hung adapter must not pin the worker.
FM_INTEGRATION_TEST_TIMEOUT_MS=30000
# Periodic sweep for in_progress push rows orphaned by a worker crash.
FM_PUSH_RECLAIM_INTERVAL_MS=300000
# Plugin upload zip-bomb guards.
FM_PLUGIN_MAX_FILES=10000
FM_PLUGIN_MAX_DEPTH=3
FM_PLUGIN_MAX_UNCOMPRESSED_BYTES=104857600
# AlertEngine per-event rule-evaluation parallelism. Higher = faster fan-out, more DB load.
FM_ALERT_DISPATCH_CONCURRENCY=8
# Hard deadline on AlertEngine.handleGroupFlush (ms).
FM_GROUP_FLUSH_TIMEOUT_MS=30000
# Cap on audit + delivery_attempts error_message columns; oversize input gets a truncation marker.
FM_PERSISTED_ERROR_MESSAGE_MAX_CHARS=2048

# ─── Fleet Manager Memory ────────────────────────────────
# Node.js heap size in MB. Parity with cloud-test/staging/prod (2048)
# so sustained e2e + multi-browser load doesn't OOM. 1GB was too tight.
FM_HEAP_SIZE=2048

# ─── Wall Display (plain WebSocket) ─────────────────────
# Allow plain ws:// on port 80 for /shelly. Required for Wall Display
# devices whose firmware only trusts Allterco CA for TLS.
FM_PLAIN_WS=true

# ─── Defaults bootstrapped per organization on first login ───
FM_DEFAULT_DASHBOARD_NAME=Default Dashboard
FM_DEFAULT_DASHBOARD_TYPE=classic

# ─── Notification endpoint auto-disable ─────────────────────
# Consecutive delivery failures before an endpoint is auto-disabled.
FM_ENDPOINT_AUTOOFF_THRESHOLD=10

# ─── Fleet Manager Tuning ───────────────────────────────
# All optional — defaults suit small fleets. See docs/tuning.md.
#
FM_MAX_CONCURRENT_INITS=100
# FM_DEVICE_INIT_PROBE_TIMEOUT_MS=20000
# FM_MAX_CONCURRENT_EM_SYNCS=40
# FM_STATUS_QUEUE_MAX=50000
# FM_GRAFANA_PROXY_TIMEOUT_MS=30000
# FM_GRAFANA_PROXY_MAX_BYTES=52428800
# FM_SEEN_LOGIN_TOKEN_TTL_MS=7200000 # Login-audit dedup TTL (match OIDC access-token lifetime + margin)
# FM_OUTBOX_CONCURRENCY=5             # Notification outbox parallel sends
# FM_OUTBOX_MAX_ATTEMPTS=6            # Notification outbox retries before DLQ
# FM_OUTBOX_RECLAIM_INTERVAL_MIN=5                      # Interval between outbox stranded-job reclaim sweeps (min)
# FM_OUTBOX_RECLAIM_STALE_MS=1800000                    # Mark a delivery_job stranded after this many ms in processing (default 30min)
# FM_INSTANCE_ID=                                       # Instance ID baked into FM-signed PAT issuer; set unique per FM instance in multi-region deploys to stop a leaked JWT_SECRET signing valid PATs cross-instance
# FM_DELIVERY_HTTP_TIMEOUT_MS=10000   # Per-request timeout for webhook adapters
# FM_DELIVERY_ERROR_SNIPPET_MAX=500   # Bytes of error body kept in delivery_attempts
# FM_ALERT_BATTERY_DEFAULT_PCT=20     # Fallback threshold for battery_below rules
# FM_TEMPLATE_MAX_OUTPUT_CHARS=4000   # Max chars in rendered notification template output
# FM_ALERT_PREVIEW_MAX_DEVICES=5000   # Max devices scanned by Alert.Rule.Preview
# FM_ALERT_PREVIEW_MAX_MATCHES=200    # Max matches returned by Alert.Rule.Preview
# FM_AUDIT_MAX_RETRIES=3              # Audit log write retries before drop (loud warn on drop)
# FM_PLUGIN_COMMAND_TIMEOUT_MS=30000  # Max time a single plugin command may stay pending
# FM_PLUGIN_SHUTDOWN_TIMEOUT_MS=5000  # Grace period before force-terminating plugin workers on shutdown
# FM_PLUGIN_COMMAND_QUEUE_MAX=1000    # Per-worker in-flight cap; further commands reject with queue-full
# FM_BOOT_BACKFILL_CONCURRENCY=16     # Concurrent legacy-snapshot backfill writes during boot
# FM_DEVICE_GROUPS_CACHE_MAX=10000    # Max shellyID→groups cache entries (LRU eviction)
# FM_GROUP_CACHE_MAX_ORGS=500         # Max orgs in CommandSender shared group cache (LRU)
# FM_DEVICE_FILTERED_CACHE_MAX_ENTRIES=200  # Max users in DeviceComponent filtered-list cache
# FM_DEVICE_CALL_MAX_PARAMS_BYTES=65536     # Max bytes for Device.Call params payload
# FM_DEVICE_CALL_MAX_METHOD_LENGTH=160      # Max method-name length in Device.Call
# FM_TELEMETRY_MAX_KEYS=200           # Cardinality cap for System.SubmitTelemetry
# FM_BUILD_COMMIT=                    # Auto-set by deploy.sh / CI; surfaced at /health.commit
# FM_AUDIT_QUEUE_HARD_MAX=10000       # Hard cap on AuditLogger queue (drops oldest beyond)
# FM_DEVICE_ACCESS_CACHE_MAX=5000     # Per-sender device-access cache size (LRU)
# FM_ALERT_RULES_CACHE_MAX=1000       # Max orgs tracked in AlertEngine rule cache
# FM_ALERT_RULES_CACHE_TTL_MS=3600000 # Alert rules cache TTL (ms, default 1h — stale orgs drop out)
# FM_OBSERVABILITY_METRIC_KEY_LIMIT=5000 # Per-map key cap for rpc/db timings/counters/ws types (LRU)
# FM_OBS_SLOW_RPC_OFFSET_MS=100         # Ms over rolling P95 that flags an RPC as slow
# FM_FIRMWARE_VERIFY_TIMEOUT_MS=120000  # Firmware auto-update: total verify wait (ms)
# FM_FIRMWARE_VERIFY_POLL_MS=5000       # Firmware auto-update: poll interval while verifying (ms)
# FM_HTTP_RATELIMIT_API_SWITCH_PER_MIN=60              # Per-caller (user/IP) cap for /api/switch
# FM_HTTP_RATELIMIT_REPORTS_DOWNLOAD_PER_MIN=30        # /api/reports/download, /api/exports/download, /api/audit-log/download(-ticket)
# FM_HTTP_RATELIMIT_MEDIA_UPLOAD_PER_MIN=20            # /media/upload*, /media/getAllBackgrounds, /media/getAllReportImages
# FM_UPLOAD_TICKET_TTL_MS=300000                       # one-time upload ticket TTL
# FM_UPLOAD_SESSION_TTL_MS=3600000                     # resumable upload session TTL
# FM_UPLOAD_ASSET_CACHE_MAX_AGE_SEC=86400              # authenticated upload asset browser cache
# FM_UPLOAD_ASSET_URL_TTL_SEC=300                      # signed upload asset URL TTL
# FM_HTTP_RATELIMIT_FIRMWARE_UPLOAD_PER_MIN=10         # Per-caller cap for /media/uploadFirmwareFile
# FM_HTTP_RATELIMIT_DEVICE_PROXY_PER_MIN=60            # /api/device-proxy/:shellyID/{info,gui-debug}
# FM_HTTP_RATELIMIT_ZITADEL_WEBHOOK_PER_MIN=100        # Shared bucket for /api/zitadel/actions/(user|grant)-removed
# FM_HTTP_RATELIMIT_METRICS_PER_MIN=120                # /metrics scraper cap (2/sec)
# FM_HTTP_RATELIMIT_AUTH_SESSION_PER_MIN=30            # Shared bucket for POST+DELETE /api/auth/session
# FM_HTTP_RATELIMIT_FIRMWARE_DOWNLOAD_PER_MIN=60       # Token-gated /media/firmware-file/:token downloads
# FM_HTTP_RATELIMIT_LOGIN_FLOW_PER_MIN=60              # Wall Display POST /auth/login_flow
# FM_WS_HEARTBEAT_CHUNK_SIZE=100                       # Clients pinged per heartbeat tick batch
# FM_AUDIT_EXPORT_BATCH_SIZE=5000                      # Audit-export rows fetched per DB batch
# FM_AUDIT_EXPORT_MAX_ROWS=100000                      # Audit-export hard row cap per CSV
# FM_BACKUP_NAME_MAX_LENGTH=200                        # Max chars accepted for a backup name
# FM_DEVICE_INGRESS_CREDENTIAL_STAGE_CONCURRENCY=8     # Concurrent stage_push calls in a bulk rotate
# FM_DEVICE_INGRESS_CREDENTIAL_STAGE_TIMEOUT_MS=10000  # Per-device stage timeout in a bulk rotate
# FM_DEVICE_INGEST_DRAINER_POISON_DELIVERIES=5         # XPENDING delivery-count above which the ingest drainer drops a poison row
# FM_DB_QUERY_STATEMENT_TIMEOUT_MS=30000               # pg pool statement_timeout for bare queryRows; 0 disables
# FM_REDIS_DISABLED=false                            # Emergency: disable all Redis hot-path reads + writes
# Empty = compose uses authenticated redis://fm-default:${REDIS_FM_PASSWORD}@redis:6379.
FM_REDIS_URL=
# FM_REDIS_KEY_PREFIX=fm                              # Deployment-wide prefix for new key shapes
# FM_REDIS_CONNECT_TIMEOUT_MS=10000                   # TCP connect timeout for the shared client
# FM_REDIS_COMMAND_TIMEOUT_MS=0                       # Per-command timeout (0 = ioredis default; opt-in)
# FM_REDIS_CMD_RETRIES_MAX=3                          # Max retries per Redis cmd
# FM_REDIS_SUB_BACKOFF_MAX_MS=5000                    # Subscribe-side reconnect backoff ceiling
# FM_WS_STREAM_PREFIX=fm:evt                          # Per-session WS stream key prefix
# FM_WS_STREAM_MAXLEN=10000                           # MAXLEN ~ trim point per session
# FM_WS_STREAM_TTL_MS=3600000                         # Stream TTL (1h) — auto-expire on disconnect
# FM_WS_STREAM_BLOCK_MS=1000                          # XREADGROUP BLOCK ms
# FM_WS_STREAM_BATCH_SIZE=100                         # XREADGROUP COUNT
# FM_WS_SENDER_PAUSE_BYTES=1048576                    # Sender loop pauses above this bufferedAmount
# FM_WS_SOCKET_OPEN_TIMEOUT_MS=5000                   # Bounded wait for WS OPEN before PEL replay (prevents stranded entries)
# FM_WS_SOCKET_OPEN_POLL_MS=25                        # Poll interval inside the WS-open bounded wait
# FM_AUDIT_OVERFLOW_STREAM_KEY=fm:audit:overflow      # Audit DLQ stream key
# FM_AUDIT_OVERFLOW_MAXLEN=100000                     # Audit DLQ MAXLEN trim point
# FM_AUDIT_OVERFLOW_TTL_MS=86400000                   # Audit DLQ TTL (24h)
# FM_AUDIT_DRAINER_BATCH_SIZE=100                     # Audit drainer XREADGROUP COUNT
# FM_AUDIT_DRAINER_BLOCK_MS=1000                      # Audit drainer XREADGROUP BLOCK ms
# FM_AUDIT_DRAINER_RETRY_MS=5000                      # Drainer retry backoff after Postgres failure
# FM_AUDIT_DRAINER_POISON_DELIVERIES=10                 # Drop audit entries after N redeliveries (poison cap, min 2)
# FM_AUDIT_EXPORTS_CLEANUP_INTERVAL_MS=300000           # Audit-export CSV cleanup interval ms (default 5min)
# FM_AUDIT_EXPORT_TTL_MS=3600000                        # Audit-export file + download-ticket TTL ms (default 1h)
# FM_STATUS_OVERFLOW_STREAM_KEY=fm:status:overflow    # Status flush DLQ stream
# FM_STATUS_OVERFLOW_MAXLEN=100000                    # Status DLQ MAXLEN
# FM_STATUS_OVERFLOW_TTL_MS=86400000                  # Status DLQ TTL (24h)
# FM_STATUS_DRAINER_BATCH_SIZE=100                    # Status drainer XREADGROUP COUNT
# FM_STATUS_DRAINER_BLOCK_MS=1000                     # Status drainer XREADGROUP BLOCK ms
# FM_STATUS_DRAINER_RETRY_MS=5000                     # Status drainer retry backoff
# FM_STATUS_REDIS_SHADOW=false                       # Also append status batches to Redis while keeping direct DB writes
# FM_STATUS_REDIS_FIRST=false                        # Write status through Redis stream only
# FM_STATUS_STREAM_KEY=fm:status:overflow            # Redis-first status stream key
# FM_DEVICE_SNAPSHOT_REDIS_SHADOW=false              # Also append device snapshots to Redis while keeping direct DB writes
# FM_DEVICE_SNAPSHOT_REDIS_FIRST=false               # Write device snapshots through Redis stream only
# FM_DEVICE_SNAPSHOT_STREAM_KEY=fm:device:snapshot   # Device snapshot stream key
# FM_DEVICE_EVENTS_REDIS_SHADOW=false                # Also append device events to Redis while keeping direct DB writes
# FM_DEVICE_EVENTS_REDIS_FIRST=false                 # Write device-event history through Redis stream only
# FM_DEVICE_EVENTS_STREAM_KEY=fm:device-event        # Device-event history stream key
# FM_DEVICE_INGEST_STREAM_PREFIX=fm:device:ingest     # Device ingestion stream key prefix (shuffle-sharded)
# FM_DEVICE_INGEST_LANES=32                           # Shuffle-shard lane count
# FM_DEVICE_INGEST_MAXLEN=50000                       # Per-lane MAXLEN
# FM_DEVICE_INGEST_TTL_MS=3600000                     # Per-lane TTL (1h)
# FM_DEVICE_INGEST_DRAINER_BATCH_SIZE=200             # Drainer XREADGROUP COUNT
# FM_DEVICE_INGEST_DRAINER_BLOCK_MS=1000              # Drainer XREADGROUP BLOCK ms
# FM_DEVICE_INGEST_DRAINER_RETRY_MS=5000              # Drainer retry backoff
# FM_DEVICE_INGEST_CAPTURE=false                     # Per-frame XADD durability (off by default — hot-path cost)
# FM_DEVICE_INGEST_DRAIN_AT_BOOT=false                # Replay pending PEL frames at startup
# FM_PUBSUB_CHANNEL_PREFIX=fm                         # Pub/Sub channel namespace
# FM_DEVICE_RATE_EWMA_ALPHA=0.3                       # EWMA smoothing for per-device event rate
# FM_DEVICE_RATE_ANOMALY_HZ=10                        # Hz threshold to flag a device noisy
# FM_DEVICE_RATE_RECOVERY_HZ=2                        # Hz below which flag clears (hysteresis)
# FM_DEVICE_RATE_TRACKED_MAX=20000                    # Max devices tracked (LRU)
# FM_DEVICE_RATE_INSTANT_CAP_HZ=100                   # Cap on per-event instant rate (defends EWMA from sub-ms gaps)
# FM_LEADER_LEASE_MS=10000                           # Leader lease lifetime
# FM_LEADER_RENEW_MS=3000                            # Leader renew interval (< lease)
# FM_DEVICE_LIST_DB_PAGE_MAX=500                       # device.list DB-side page cap
# FM_DEVICE_RELATIONSHIP_QUERY_DEFAULT_LIMIT=25        # device.Relationships.Query default page size
# FM_DEVICE_RELATIONSHIP_QUERY_MAX_LIMIT=50            # device.Relationships.Query max page size
# FM_DEVICE_RELATIONSHIP_DEPTH_TWO_MAX_EXPANSIONS=25   # device.Relationships.Get depth=2 related-device expansion cap
# FM_DEVICE_RELATIONSHIP_DEVICE_SIDE_FAMILY_LIMIT=50   # device.Relationships.Get device-side facts per family
# FM_ENTITY_LIST_DB_PAGE_MAX=500                       # entity.list early-exit page cap
# FM_ENERGY_QUERY_ROW_LIMIT=2000000                    # Energy.Query DB row limit
# FM_REPORT_MAX_ROWS=2000000                           # Report pre-flight row cap
# FM_REPORT_MAX_DEVICES=10000                          # Report pre-flight device cap
# FM_REPORT_STREAM_CHUNK_ROWS=1000                     # Report CSV stream chunk size
# FM_REPORT_MAX_RANGE_DAYS=365                         # Report date-range cap
# FM_REPORT_GZIP_CSV_ARTIFACTS=true                    # Write report CSV artifacts as .csv.gz
# FM_REPORT_HTML_SUMMARY_MAX_ROWS=500                  # Rows retained in report HTML summaries
# FM_REPORT_OWNERSHIP_TTL_DAYS=30                      # Report artifact/job retention window
# FM_REPORT_CLEANUP_INTERVAL_MS=300000                 # Report artifact cleanup sweep interval
# FM_REPORT_CANCEL_POLL_MS=1000                        # Report cancellation poll interval
# FM_REPORT_EXPORT_MAX_ATTEMPTS=3                      # Durable report worker retry attempts
# FM_REPORT_NOMINAL_VOLTAGE=230                       # EN 50160 nominal grid voltage (use 120 for US grids)
# FM_REPORT_NOMINAL_HZ=50                             # Nominal grid frequency (use 60 for US grids)
# FM_LOCATION_EVENT_REPLAY_MAX_ROWS=50000              # Location.EventReplay materialised-row cap per request
# FM_STORAGE_GETALL_MAX_BYTES=2097152                  # Storage.GetAll response cap; throws when exceeded (0 = uncapped). Callers should use Keys + GetItem.
# FM_LOCATION_EVENT_REPLAY_CACHE_HISTORICAL_SEC=86400   # Redis TTL for immutable (historical) windows
# FM_LOCATION_EVENT_REPLAY_CACHE_ROLLING_SEC=30         # Redis TTL for rolling (open-ended) windows
# FM_LOCATION_EVENT_REPLAY_CACHE_IMMUTABLE_LAG_SEC=60   # Lag before a window is considered historical
# FM_LOCATION_EVENT_REPLAY_CACHE_KEY_PREFIX=fm:eventreplay:v1   # Redis key prefix (bump to force flush)
# FM_SMTP_CONNECTION_TIMEOUT_MS=10000                  # SMTP connect timeout
# FM_SMTP_GREETING_TIMEOUT_MS=10000                    # Wait for SMTP banner after connect
# FM_SMTP_SOCKET_TIMEOUT_MS=30000                      # Idle-socket timeout during SMTP conversation
# FM_SMTP_OAUTH2_GOOGLE_TOKEN_URL=https://oauth2.googleapis.com/token    # Override for test mocks
# FM_SMTP_OAUTH2_MICROSOFT_TOKEN_URL_TEMPLATE=https://login.microsoftonline.com/{tenant}/oauth2/v2.0/token  # Sovereign cloud override ({tenant} substituted)
# FM_SMTP_DEFAULT_TLS_MIN_VERSION=TLSv1.2                  # TLSv1.2 or TLSv1.3 — applied when endpoint config has no tls.minVersion
# FM_SMTP_DEFAULT_TLS_REJECT_UNAUTHORIZED=true             # false only for pinned self-signed internal relays
# FM_SMTP_POOL_MAX=50                                    # Max cached nodemailer transporters; 0 disables pooling
# FM_SMTP_POOL_TTL_MS=600000                             # Transporter idle TTL (ms); evicted + closed after
# Email notification branding (used by the default HTML template)
# FM_EMAIL_BRAND_NAME="Fleet Manager"
# FM_EMAIL_BRAND_LOGO_URL=               # Optional — absolute https URL to a small logo
# FM_EMAIL_COLOR_INFO=#3b82f6
# FM_EMAIL_COLOR_WARNING=#f59e0b
# FM_EMAIL_COLOR_CRITICAL=#ef4444
# FM_ALERT_LINK_BASE=                    # e.g. https://fleet.example.com/alerts — shared by all delivery adapters; empty hides button/link
# Notification display — shared severity/state labels across all adapters
# FM_NOTIFICATION_SEVERITY_EMOJI_CRITICAL=🔴
# FM_NOTIFICATION_SEVERITY_EMOJI_WARNING=🟡
# FM_NOTIFICATION_SEVERITY_EMOJI_INFO=🔵
# FM_NOTIFICATION_STATE_EMOJI_ACKNOWLEDGED=✅
# FM_NOTIFICATION_STATE_EMOJI_RESOLVED=✔️
# FM_NOTIFICATION_STATE_LABEL_ACKNOWLEDGED=acknowledged
# FM_NOTIFICATION_STATE_LABEL_RESOLVED=resolved
# FM_NOTIFICATION_SLACK_SEVERITY_EMOJI_CRITICAL=:rotating_light:
# FM_NOTIFICATION_SLACK_SEVERITY_EMOJI_WARNING=:warning:
# FM_NOTIFICATION_SLACK_SEVERITY_EMOJI_INFO=:information_source:
# Alert grouping — Alertmanager-style batching (prevents 7k-device storms = 7k notifications)
# FM_ALERT_GROUP_WAIT_SEC=60                # wait after first alert in a new group before first notify
# FM_ALERT_GROUP_INTERVAL_SEC=300           # min delay between subsequent batches for same group (5m)
# FM_ALERT_REPEAT_INTERVAL_SEC=14400        # renotify unresolved group every 4h (must be multiple of GROUP_INTERVAL)
# FM_ALERT_GROUP_BY=organization_id,rule_id,severity   # CSV of labels forming the group key
# FM_ALERT_GROUP_MAX_MEMBERS=1000           # max members per group before early flush (PagerDuty proven cap)
# FM_ALERT_STORM_SUMMARY_THRESHOLD=25       # group > this many alerts → render summary card, not per-alert list
# FM_EMAIL_ATTACHMENT_HTTP_TIMEOUT_MS=10000  # Per-attachment URL-fetch timeout
# FM_EMAIL_ATTACHMENT_MAX_BYTES=5242880   # Per-attachment size cap (5 MiB default)
# FM_FLOOR_PLAN_MAX_BYTES=5242880         # Floor-plan upload size cap (5 MiB default)
# FM_VIRTUAL_IMAGE_MAX_BYTES=1048576       # Virtual-component icon upload size cap (1 MiB default)
# FM_EMAIL_ATTACHMENT_ALLOW_HTTP=false    # true = allow http:// URLs (internal CDNs only)
# FM_EMAIL_MAX_ATTACHMENTS=10             # Max attachments per template/endpoint
# FM_EMAIL_ATTACHMENT_CACHE_MAX_BYTES=52428800  # Fetched-attachment byte cache cap (50 MiB)
# FM_EMAIL_ATTACHMENT_CACHE_TTL_MS=600000       # Cached-attachment TTL (10 min)
# FM_EMAIL_ASSETS_ORG_QUOTA_BYTES=52428800      # Binary-asset total cap per org (50 MiB)
# FM_EMAIL_ASSETS_CONTENT_TYPES=image/png,image/jpeg,image/gif,image/svg+xml,image/webp
# FM_OAUTH_REDIRECT_BASE=https://fleet.example.com   # Required for in-app Gmail/M365 consent; <base>/api/oauth/callback/email must be whitelisted in the OAuth app
# FM_OAUTH_GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.send
# FM_OAUTH_MICROSOFT_SCOPES=offline_access https://outlook.office.com/SMTP.Send
# FM_OAUTH_STATE_TTL_SECONDS=600                     # How long a Start state is valid before it expires
# FM_OAUTH_STATE_PRUNE_INTERVAL_MS=300000            # Periodic cleanup of expired/consumed states (5 min)
# FM_OAUTH_GMAIL_AUTH_URL=https://accounts.google.com/o/oauth2/v2/auth
# FM_OAUTH_MICROSOFT_AUTH_URL_TEMPLATE=https://login.microsoftonline.com/{tenant}/oauth2/v2.0/authorize
# Telegram Bot API — adapter reads sendMessage / editMessageText / getMe
# FM_TELEGRAM_API_BASE=https://api.telegram.org    # Override for air-gapped relay
# FM_TELEGRAM_MESSAGE_MAX_CHARS=4096              # Telegram's hard cap; messages truncated with "…"
# FM_TELEGRAM_DEFAULT_TEMPLATE=                   # Instance-wide template; empty = built-in structured default
# Microsoft Teams workflow webhook — adapter posts Adaptive Card to Power Automate HTTP trigger
# FM_TEAMS_CARD_VERSION=1.5                       # Adaptive Card schema version; pin to 1.4 only for legacy Teams clients
# FM_TEAMS_MAX_CARD_BYTES=25000                   # Card size cap; Teams hard limit ~28KB
# FM_TEAMS_DEFAULT_TEMPLATE=                      # Instance-wide card JSON override; empty = built-in chrome
# FM_TEAMS_WEBHOOK_ALLOWED_HOSTS=                 # CSV of host suffixes; empty = allow any https URL (SSRF hardening)
# FM_TEAMS_MENTION_SEVERITIES=critical            # CSV of severities where @mentions fire; empty = disabled
# FM_LOCAL_WS_PORT=                      # Loopback Node-RED WS port (default = FLEET_MANAGER_PORT + 1)
# Location taxonomy — CSV option-set defaults for Location.ListKinds.
# Empty = built-in defaults; end users may also submit custom values.
# FM_LOCATION_SITE_TYPES=office,warehouse,retail,data-center,manufacturing,hospitality,healthcare,education,residential,mixed-use
# FM_LOCATION_BUILDING_TYPES=office,warehouse,retail,data-center,manufacturing,hospitality,healthcare,education,residential,industrial
# FM_LOCATION_ROOM_TYPES=office,meeting,server,mechanical,storage,kitchen,bathroom,lobby,cleanroom,lab
# FM_LOCATION_OPERATIONAL_TIERS=critical,production,staging,development
# FM_LOCATION_COMPLIANCE_TAGS=HIPAA,PCI-DSS,SOC2,ISO-27001,GDPR-strict,FDA-regulated,cleanroom
# FM_LOCATION_ACCESS_PROCEDURES=public,badge,biometric,escort-required,security-cleared
# FM_LOCATION_REGULATORY_ZONES=EU,US,UK,APAC,LATAM,MENA,OTHER
# FM_LOCATION_ENERGY_CERTIFICATIONS=LEED-Platinum,LEED-Gold,LEED-Silver,LEED-Certified,BREEAM-Outstanding,BREEAM-Excellent,DGNB-Platinum,DGNB-Gold,none
# FM_LOCATION_CONTACT_ROLES=Facility Manager,IT Operations,Security,Maintenance,Reception,Owner,Tenant,Emergency
# FM_RATE_LIMIT_GENERAL_RPM=240       # Per-(user, method) RPC limit — applied on HTTP and WS paths
# FM_RATE_LIMIT_EXPENSIVE_RPM=30      # Per-(user, method) limit for admin/write methods — both transports
# FM_RATE_LIMIT_EXPENSIVE_METHODS=    # CSV override for stricter-bucket methods (defaults bundled in code)
# FM_DEVICE_PROBE_TIMEOUT_MS=5000     # /api/device-proxy health-check timeout (ms)
# FM_NODE_RED_PORT=1880               # Node-RED admin UI port
# FM_NODE_RED_HOST=0.0.0.0            # Node-RED admin UI bind host
# FM_NODE_RED_USER_DIR=./cfg/node-red # Node-RED user directory
# FM_NODE_RED_FLOW_FILE=flows_fleetmanager.json  # Node-RED flow file name
# FM_NODE_RED_ORG_ID=                # Tenant pin for in-process Node-RED loopback (empty = denied)
# FM_NODE_RED_PERMISSIONS=         # CSV of perms granted to the loopback Node-RED user (empty = locked down)
# FM_WS_USER_REFRESH_INTERVAL_MS=30000  # WS sender re-resolves user from token after this many ms
# FM_GRAFANA_DS_MAX_OPEN_CONNS=10     # Grafana datasource pool: max open connections
# FM_GRAFANA_DS_MAX_IDLE_CONNS=10     # Grafana datasource pool: max idle connections
# FM_GRAFANA_DS_CONN_LIFETIME_SEC=14400  # Grafana datasource pool: connection lifetime (s)
# FM_DASHBOARD_DEFAULT_TARIFF=0       # Default tariff applied to new dashboards
# FM_DASHBOARD_DEFAULT_CURRENCY=EUR   # Default currency code for new dashboards
# FM_DASHBOARD_DEFAULT_RANGE=last_7_days  # Default time range for new dashboards
# FM_DASHBOARD_REFRESH_MS=60000       # Default auto-refresh interval for new dashboards (ms)

# ─── OIDC scope (frontend → Zitadel) ─────────────────────
# Space-separated list. Keep urn:zitadel:iam:user:resourceowner — backend
# needs the resourceowner:id claim to scope RPCs to the user's organization.
FM_OIDC_SCOPE=openid profile email offline_access urn:zitadel:iam:user:resourceowner

# ─── Group-Type Policy Defaults (operator may override per group in UI) ─
# FM_GROUP_POLICY_SEVERITY_FLOOR_STANDARD=
# FM_GROUP_POLICY_SEVERITY_FLOOR_OPERATIONAL=warning
# FM_GROUP_POLICY_SEVERITY_FLOOR_CRITICAL=critical
# FM_GROUP_POLICY_SEVERITY_FLOOR_CUSTOM=
# FM_GROUP_POLICY_RETENTION_STANDARD_DAYS=7
# FM_GROUP_POLICY_RETENTION_OPERATIONAL_DAYS=30
# FM_GROUP_POLICY_RETENTION_CRITICAL_DAYS=365
# FM_GROUP_POLICY_RETENTION_CUSTOM_DAYS=
# FM_GROUP_POLICY_RETENTION_FALLBACK_DAYS=7
# FM_GROUP_POLICY_SWEEP_INTERVAL_MINUTES=60
# FM_GROUP_POLICY_AUDIT_RETENTION_STANDARD_DAYS=90
# FM_GROUP_POLICY_AUDIT_RETENTION_OPERATIONAL_DAYS=180
# FM_GROUP_POLICY_AUDIT_RETENTION_CRITICAL_DAYS=730
# FM_GROUP_POLICY_AUDIT_RETENTION_CUSTOM_DAYS=
# FM_GROUP_POLICY_AUDIT_RETENTION_FALLBACK_DAYS=90

# ─── Frontend Runtime Tunables (entrypoint → runtime-config.js) ─
# FM_LOG_BUFFER_MAX=2000     # Max log entries kept in the in-memory console buffer
# FM_LOG_CATEGORY_MAX=100    # Max distinct log4js categories shown in filters
# FM_AUDIT_PAGE_SIZE=100     # Page size for /monitoring/audit-log search
# FM_AUDIT_PAYLOAD_PREVIEW_MAX=80    # Settings/audit payload truncation (chars)
# FM_RPC_AUDIT_LOG_PATH=/monitoring/audit-log  # Deep-link target from settings/audit
# FM_ZITADEL_PASSWORD_MIN_LENGTH=8 # Minimum password length shown in user creation

# ─── Fleet DB (TimescaleDB) Tuning ──────────────────────
# Postgres memory settings. Tune based on available RAM.
# Default values fit 8GB machines (RPi 5, mini PCs, old laptops).
# For 16GB+ machines: PG_SHARED_BUFFERS=512MB, PG_EFFECTIVE_CACHE=1GB
PG_SHARED_BUFFERS=256MB
PG_EFFECTIVE_CACHE=512MB
PG_WORK_MEM=4MB
PG_MAINT_WORK_MEM=64MB
PG_MAX_CONNECTIONS=100

# ─── Zitadel Tuning ─────────────────────────────────────
# Zitadel is lightweight — these rarely need changing.
ZITADEL_PG_SHARED_BUFFERS=64MB
ZITADEL_PG_EFFECTIVE_CACHE=128MB
ZITADEL_PG_WORK_MEM=2MB
ZITADEL_MEM_LIMIT=256MiB

# ─── Fleet Manager Tuning ───────────────────────────────
# Performance tuning. Defaults suit small/medium fleets (up to ~500 devices).
# Uncomment and adjust for your hardware and fleet size.
#
FM_MAX_CONCURRENT_INITS=100       # Parallel device inits on reconnect
# FM_DEVICE_INIT_PROBE_TIMEOUT_MS=20000   # Per-RPC probe timeout on connect
# FM_FIRMWARE_UNIT_TIMEOUT_MS=600000      # firmware push per-unit deadline
# FM_BACKUP_UNIT_TIMEOUT_MS=120000        # backup per-unit deadline
# FM_CREDENTIAL_PUSH_ROW_TIMEOUT_MS=60000 # credential push per-row deadline
# FM_CERT_PUSH_ROW_TIMEOUT_MS=120000      # cert push per-row deadline
# FM_CERT_OPENSSL_TIMEOUT_MS=10000        # openssl subprocess SIGTERM after ms
# FM_PAT_REVOKE_ROW_TIMEOUT_MS=30000      # Zitadel PAT revoke per-row deadline
# FM_MAX_CONCURRENT_EM_SYNCS=40     # Parallel energy meter data syncs
# FM_RPC_TIMEOUT_MS=60000           # Device RPC call timeout (ms)
# FM_STATUS_QUEUE_MAX=50000         # Max buffered status messages

# ─── Data Retention ─────────────────────────────────────
# How long to keep data before automatic cleanup.
# Uses PostgreSQL INTERVAL syntax: '24 hours', '7 days', '3 months', '1 year'
#
# STATUS_RETENTION: High-frequency device telemetry (temperature, power, etc.)
#   Reported every 10-60s per device. ~2.6M rows/day for 300 devices.
#   7 days keeps ~500MB compressed. Decrease to '24 hours' to save space.
STATUS_RETENTION=7 days

# EM_STATS_RETENTION: raw energy meter readings (kWh, voltage, current).
#   Raw is the 1-month hot window for fine (1-5 min) detail. Long-term energy
#   history lives in the 15-minute rollup (device_em.energy_15min), so raw is
#   kept short on purpose. Do not raise without sizing raw storage.
EM_STATS_RETENTION=31 days

# EM_ROLLUP_RETENTION: long-term 15-minute energy rollup (device_em.energy_15min).
#   Empty = kept forever (no expiry) — the default. Set a value (e.g. '7 years')
#   once a legal/commercial retention policy is decided. If the data is
#   customer-linked, GDPR storage-limitation may cap how long it may be kept.
EM_ROLLUP_RETENTION=

# AUDIT_LOG_RETENTION: User actions and RPC calls (login, firmware update, etc.)
#   ~100-1000 rows/day depending on usage. 90 days keeps ~50-200MB.
#   Set to '1 year' for compliance, '30 days' to save space.
AUDIT_LOG_RETENTION=90 days

# ─── Dozzle Log Viewer (used with --logging) ────────────────
# Web UI port for browsing container logs in real-time.
DOZZLE_PORT=9999

# ─── mDNS Repeater (used with --with mdns) ────────────────
# Leave empty for auto-detection (recommended).
# MDNS_ON = host network interface where Shelly devices are (e.g. eth0, enp1s0)
# MDNS_TO = Docker bridge network (auto-created as br-<project>)
MDNS_ON=
MDNS_TO=

# ─── Frontend UI Tunables (entrypoint → runtime-config.js) ─
# Details: docs/env-reference.md
# Runtime bootstrap metadata.
FM_API_CONTRACT_VERSION=1
FM_UI_CONTRACT_VERSION=1
FM_FRONTEND_ARTIFACT_ID=default-template
FM_FRONTEND_ARTIFACT_VERSION=default
FM_DEPLOYMENT_MODE=oss
FM_TOPOLOGY_MODE=single-tenant
FM_CLIENT_ID=single
FM_ENVIRONMENT_ID=public
FM_COMPOSE_PROJECT_NAME=fleet-public
FM_MANAGED_BY=fleet-manager
FM_SAFE_MODE=false
# Control-plane contract rollout flags. Keep strict/export flags off until reviewed.
FM_CONTRACT_HEALTH_V2=true
FM_CONTRACT_RUNTIME_IDENTITY=true
FM_CONTRACT_DOCKER_LABELS=true
FM_CONTRACT_CHECK_RESULTS=true
FM_CONTRACT_STRICT_CI=false
FM_CONTRACT_MANIFEST_V2=true
FM_CONTRACT_EXPORT_SANITIZED_MANIFEST=true
FM_CONTRACT_DEVICE_USAGE_API=true
# "X ago" ticker refresh (ms).
FM_UI_NOW_TICKER_MS=30000
# Skeleton cards on list pages during first fetch.
FM_UI_LIST_SKELETON_COUNT=4
# Alert urgency thresholds (min). amber=warning, danger=overdue.
FM_UI_ALERT_TIMER_CRITICAL_AMBER_MINS=5
FM_UI_ALERT_TIMER_CRITICAL_DANGER_MINS=15
FM_UI_ALERT_TIMER_WARNING_AMBER_MINS=30
FM_UI_ALERT_TIMER_WARNING_DANGER_MINS=120
FM_UI_ALERT_TIMER_INFO_AMBER_MINS=120
FM_UI_ALERT_TIMER_INFO_DANGER_MINS=480
# Silence duration presets (min).
FM_UI_SILENCE_PRESET_MINUTES=15,60,240,480,1440
# "Silence until tomorrow" target hour (0–23).
FM_UI_SILENCE_TOMORROW_HOUR=9
# Toast auto-dismiss (ms): plain / with-action button.
FM_UI_TOAST_DEFAULT_MS=5000
FM_UI_TOAST_ACTION_MS=8000
# Max toasts shown at once; oldest evicted.
FM_UI_TOAST_MAX_STACK=5

FM_UI_URL_SYNC_DEBOUNCE_MS=300
FM_UI_DUPLICATE_CHECK_DEBOUNCE_MS=400
FM_UI_TEMPLATE_PREVIEW_DEBOUNCE_MS=300
FM_UI_OPTIMISTIC_FLASH_MS=220
FM_UI_OPTIMISTIC_RECONCILE_TIMEOUT_MS=3000
FM_UI_OPTIMISTIC_REAPER_MS=60000
FM_UI_SEARCH_THRESHOLD=0.4
FM_UI_SEARCH_IGNORE_LOCATION=true
FM_UI_FIRINGS_PAGE_SIZE=100
FM_UI_GROUP_ACTIVITY_PAGE_SIZE=200
# EM net-energy preview cap (rows shown under the table) and paging safety cap.
FM_UI_EM_NET_PREVIEW_ROWS=12
FM_UI_EM_NET_PAGE_LIMIT=200
# Operations dashboard "X seconds ago" refresh interval.
FM_UI_OPS_REFRESH_MS=5000

# Map / visualization (MapLibre + deck.gl). Free, no-key default style.
FM_UI_MAP_STYLE_URL=https://basemaps.cartocdn.com/gl/dark-matter-nolabels-gl-style/style.json
FM_UI_MAP_SINGLE_PIN_ZOOM=11
FM_UI_MAP_DETAIL_ZOOM=15
FM_UI_MAP_FIT_PADDING_PX=48
FM_UI_MAP_FIT_MAX_ZOOM=12
FM_UI_MAP_FLY_DURATION_MS=600
FM_UI_MAP_3D_PITCH_DEG=55
FM_UI_MAP_EXTRUSION_MIN_ZOOM=14
# Floor plan canvas (PixiJS).
FM_UI_FLOORPLAN_HEIGHT_PX=480
FM_UI_FLOORPLAN_MOBILE_HEIGHT_PX=360
# Decorative login globe (cobe).
FM_UI_LOGIN_GLOBE_SIZE_PX=520
# Event replay trail length, seconds.
FM_UI_REPLAY_TRAIL_LENGTH_SEC=300
# World map overview zoom for multi-pin first paint (fitBounds overrides).
FM_UI_MAP_OVERVIEW_ZOOM=2
# 3D toggle pitch-ease duration (ms).
FM_UI_MAP_PITCH_EASE_DURATION_MS=500
# Cytoscape topology layout knobs.
FM_UI_TOPOLOGY_ANIMATION_DURATION_MS=800
FM_UI_TOPOLOGY_NODE_REPULSION=4500
FM_UI_TOPOLOGY_IDEAL_EDGE_LENGTH=80
FM_UI_TOPOLOGY_EDGE_ELASTICITY=0.45
FM_UI_TOPOLOGY_GRAVITY=0.25
FM_UI_TOPOLOGY_TILE=true

# Keyboard shortcuts. DSL: mod+key, mod+shift+key, symbol, 'escape'. Empty = disabled.
FM_UI_SHORTCUT_HELP=?
FM_UI_SHORTCUT_CLOSE_INSPECTOR=escape
FM_UI_SHORTCUT_SEARCH_FOCUS=mod+k
FM_UI_SHORTCUT_DASHBOARD_UNDO=mod+z
FM_UI_SHORTCUT_DASHBOARD_REDO=mod+shift+z
FM_UI_SHORTCUT_LOGS_FOCUS=mod+k
FM_UI_SHORTCUT_LOGS_CLEAR=mod+l
FM_UI_SHORTCUT_LOGS_CLEAR_SEARCH=escape

# Waiting Room pending-device memory bounds.
# FM_WAITING_ROOM_MAX=2000
# FM_WAITING_ROOM_TTL_MS=3600000
# FM_WAITING_ROOM_SWEEP_MS=60000
# FM_WAITING_ROOM_NOTIFY_DEBOUNCE_MS=300
# FM_WAITING_ROOM_ENRICH_TIMEOUT_MS=5000
# FM_WAITING_ROOM_RECONNECT_KEY_MAX=10000
# FM_WAITING_ROOM_RECONNECT_WINDOW_MS=60000
# FM_WAITING_ROOM_RECONNECT_MAX_PER_WINDOW=20
# FM_WAITING_ROOM_RECONNECT_BLOCK_MS=300000
# FM_WAITING_ROOM_SANITIZE_MAX_STRING_LEN=256
# FM_WAITING_ROOM_SANITIZE_MAX_COMPONENT_KEYS=64
# Opt-in deadline for waitingRoom config lookups. 0 = disabled (default).
# FM_WAITING_ROOM_CONFIG_TIMEOUT_MS=0

# Deploy startup health-wait timeouts (seconds).
# FM_STARTUP_TIMEOUT=180
# TRAEFIK_STARTUP_TIMEOUT=60

# Redis (authz cache + pub/sub for tenant-version invalidation)
REDIS_MAX_MEMORY=256mb
REDIS_APPENDONLY=yes
REDIS_APPENDFSYNC=everysec
FM_AUTHZ_L1_MAX_ENTRIES=10000
FM_AUTHZ_L1_TTL_SECONDS=60
FM_AUTHZ_L2_TTL_SECONDS=300
FM_AUTHZ_REDIS_KEY_PREFIX=authz
FM_AUTHZ_PUBSUB_CHANNEL_PREFIX=authz:invalidate
FM_AUTHZ_GROUP_DEPTH_MAX=16
FM_AUTHZ_UNUSED_THRESHOLD_DAYS=90
# Edge bot-probe block. Traefik 503s the listed scanner paths
# so they never reach FM. Set false to bypass for direct testing.
FM_EDGE_BLOCK_BOT_PROBES=true
FM_EDGE_BLOCK_BOT_PROBES_PATTERNS=^/\.(env|git|vscode|aws|ssh)|^/backup\.|^/sftp-config|^/wp-(admin|login)|^/robots\.txt|^/phpmyadmin
FM_SCOPED_PAT_RETENTION_DAYS=30
FM_SCOPED_PAT_SWEEP_INTERVAL_MS=3600000
FM_AUTHZ_INIT_RETRY_MS=30000
# Hard deadline for main() bootstrap; exit 1 with a fatal log when reached.
# Keeps a hung dependency (slow DB, stalled redis dial) from holding the pod.
FM_BOOT_TIMEOUT_MS=180000
# Delivery SSRF guard: when true, outbound webhook/email adapters allow
# private RFC1918/link-local/loopback targets. Operators with legitimate
# internal endpoints set true; default false denies them.
FM_DELIVERY_ALLOW_PRIVATE_HOSTS=false
# TTL on authz version keys — bounds leak from deleted tenants.
FM_AUTHZ_VERSION_TTL_SECONDS=2592000

# Mobile composite endpoints (Mobile.GetBootstrap / Mobile.SyncDelta)
FM_MOBILE_BOOTSTRAP_DEVICE_LIMIT=100
FM_MOBILE_SYNC_DELTA_LIMIT=500

# ── Certificate / credential store tunables ──────────────────────
# Cert push pipeline
FM_CERT_PUSH_POLL_INTERVAL_MS=1000
FM_CERT_PUSH_CONCURRENCY=8
FM_CERT_PUSH_LOCK_TIMEOUT_MS=30000
FM_CERT_PUSH_TIMEOUT_MS=30000
# Backup job pipeline
FM_BACKUP_JOB_POLL_INTERVAL_MS=1000
FM_BACKUP_JOB_CONCURRENCY=3
FM_BACKUP_JOB_TIMEOUT_MS=300000
# Firmware job pipeline
FM_FIRMWARE_JOB_POLL_INTERVAL_MS=1000
FM_FIRMWARE_JOB_CONCURRENCY=3
FM_FIRMWARE_JOB_TIMEOUT_MS=300000
# Cert expiry monitor
FM_CERT_EXPIRY_CRON_INTERVAL_MS=3600000
FM_CERT_EXPIRY_WARN_DAYS=30,14,7
FM_CERT_RENEW_THRESHOLD_DAYS=14
FM_CERT_DEVICE_VALIDITY_DAYS=365
FM_CERT_DEVICE_MAX_VALIDITY_DAYS=3650
FM_CERT_RENEW_CONCURRENCY=4
FM_CERT_ISSUE_CONCURRENCY=2

# ── Discovery / admission ────────────────────────────────────────
# Public base URL the FM is reachable at (https://fleet.example.com).
# Used by Discovery.AdmitDevice to derive the device-facing WS URL.
FM_PUBLIC_BASE_URL=
# Explicit device-facing WS URL override. Empty → derive from FM_PUBLIC_BASE_URL.
FM_DEVICE_WS_URL=
# Trust policy the device uses for outbound WS TLS. '*' = trust any.
FM_DEVICE_WS_SSL_CA=*
# How long an unclaimed admission intent survives before sweep.
FM_ADMISSION_TTL_SECONDS=300
# SSRF guard: LAN deploys set true; SaaS pointing at public devices false.
FM_DISCOVERY_ALLOW_PRIVATE=true
# Local CA mount root — IssueDeviceCert reads ca.crt/ca.key from here.
FM_LOCAL_CA_DIR=/app/state/tls

# Credential store
FM_CREDENTIAL_PASSWORD_LENGTH=32
FM_CREDENTIAL_PASSWORD_ALPHABET=alphanumeric_symbols
FM_CREDENTIAL_REVEAL_PER_ADMIN_PER_DAY=30
FM_CREDENTIAL_REVEAL_REQUIRE_REAUTH=true
# Service-user PAT rotation
FM_PAT_ROTATE_GRACE_MS=0
# Zitadel auth — set to 'jwt-profile' to retire shared client secret + PAT.
# Bootstrap generates the keyfiles under deploy/state/secrets/ and the
# runtime mounts them at /app/state/secrets/.
FM_OIDC_AUTH_METHOD=basic
FM_ZITADEL_SERVICE_AUTH=pat
# rotate-secrets command — health-check timeout after FM restart.
FM_ROTATE_HEALTH_TIMEOUT_S=60
# At-rest encryption key registry. Active key is what new writes use.
# During rotation, set _PREVIOUS to the old key + _PREVIOUS_ID to its id;
# decrypts fall through to it on auth-tag mismatch.
FM_SECRET_ENCRYPTION_KEY_PREVIOUS=
FM_SECRET_ENCRYPTION_KEY_ID=primary
FM_SECRET_ENCRYPTION_KEY_PREVIOUS_ID=previous
# Installer startup waits (seconds). Bump on slow hosts, lower on fast ones.
# DOCKER_DAEMON_TIMEOUT=120
# ZITADEL_STARTUP_TIMEOUT=180
# ZITADEL_TOKEN_TIMEOUT=60
# FM_STARTUP_TIMEOUT=180
# TRAEFIK_STARTUP_TIMEOUT=60

# Faster offline detection: ~20s worst-case (default 60s).
FM_WS_HEARTBEAT_MS=10000
FM_WS_HEARTBEAT_MISSED_PONGS_MAX=2

# Proxied installs using IP-conditioned policies must set this to the proxy CIDR(s), else client IPs collapse to the proxy IP.
#FM_WS_CLIENT_TRUSTED_PROXY_CIDRS=

# --- Energy report + carbon tuning ------------------------------------------
# Location-based marginal emission factor (g CO₂e/kWh). Default EU 2023 = 414.
# A dashboard's per-dashboard factor (set via Dashboard.Settings.Update)
# overrides this when present.
FM_ENERGY_EMISSION_FACTOR_LBM_G_PER_KWH=414

# What-if PV recommendation: default added kWp to project. 0 disables.
FM_ENERGY_WHAT_IF_SOLAR_KWP=5

# Max kWh that the time-shift recommendation may propose moving per day.
FM_ENERGY_TIMESHIFT_MAX_KWH=5

# ElectricityMaps adapter for real-time hourly grid intensity.
# Empty key → static-LBM fallback (flat curve at the configured factor).
FM_ELECTRICITY_MAPS_API_KEY=
FM_ELECTRICITY_MAPS_URL=https://api.electricitymap.org/v3
FM_ELECTRICITY_MAPS_TIMEOUT_MS=5000
FM_ELECTRICITY_MAPS_ZONE=BG
