# Fleet Management — Public / Community Deploy
#
# Pre-configured for deploy-public.sh one-click community deployment.
# Weak passwords, auto hostname. Suitable for evaluation and testing.

# ─── Project name ──────────────────────────────────────────
COMPOSE_PROJECT_NAME=fleet-public

# ─── TimescaleDB ───────────────────────────────────────────
POSTGRES_PASSWORD=fleet-public-demo

# ─── Zitadel ──────────────────────────────────────────────
ZITADEL_MASTERKEY=PublicDemo32CharsMasterKeyVal!!!
ZITADEL_POSTGRES_PASSWORD=fleet-public-demo
ZITADEL_DB_USER_PASSWORD=fleet-public-demo
ZITADEL_ADMIN_PASSWORD=FleetDemo1234!
ZITADEL_HOSTNAME=auto
ZITADEL_EXTERNALPORT=9090

# ─── Fleet Manager ────────────────────────────────────────
FM_VERSION=latest
FLEET_MANAGER_PORT=7011

# ─── Zitadel Bootstrap (OIDC setup) ─────────────────────
# These configure the Fleet Manager project and admin user created in Zitadel.
# Change before first deploy — changing after bootstrap has no effect
# (delete deploy/state/ and re-bootstrap to apply changes).
ZITADEL_PROJECT_NAME=fleet-management
FM_ADMIN_USER=fm-admin
FM_ADMIN_PASSWORD=Admin123!
FM_ADMIN_EMAIL=admin@fleet.local

# ─── Frontend Debug/Perf (runtime-injected) ─────────────
FM_DEBUG_DEFAULT=false
FM_PERF_TRACING=false
FM_OBSERVABILITY=true

# ─── Fleet Manager Memory ────────────────────────────────
# Node.js heap size in MB. Increase for large fleets (500+ devices).
# 1024 = 1GB, suitable for up to ~300 devices on 8GB machines.
FM_HEAP_SIZE=1024

# ─── Fleet DB (TimescaleDB) Tuning ──────────────────────
# Postgres memory settings. Tune based on available RAM.
# Default values fit 8GB machines (RPi 5, mini PCs, old laptops).
# For 16GB+ machines: PG_SHARED_BUFFERS=512MB, PG_EFFECTIVE_CACHE=1GB
PG_SHARED_BUFFERS=256MB
PG_EFFECTIVE_CACHE=512MB
PG_WORK_MEM=4MB
PG_MAINT_WORK_MEM=64MB
PG_MAX_CONNECTIONS=100

# ─── Zitadel Tuning ─────────────────────────────────────
# Zitadel is lightweight — these rarely need changing.
ZITADEL_PG_SHARED_BUFFERS=64MB
ZITADEL_PG_EFFECTIVE_CACHE=128MB
ZITADEL_PG_WORK_MEM=2MB
ZITADEL_MEM_LIMIT=256MiB

# ─── Data Retention ─────────────────────────────────────
# How long to keep data before automatic cleanup.
# Uses PostgreSQL INTERVAL syntax: '24 hours', '7 days', '3 months', '1 year'
#
# STATUS_RETENTION: High-frequency device telemetry (temperature, power, etc.)
#   Reported every 10-60s per device. ~2.6M rows/day for 300 devices.
#   7 days keeps ~500MB compressed. Decrease to '24 hours' to save space.
STATUS_RETENTION=7 days

# EM_STATS_RETENTION: Energy meter readings (kWh, voltage, current).
#   Reported every 1-5 min per EM device. ~500K rows/day for 100 EM devices.
#   1 year keeps ~2-5GB compressed. Useful for energy cost analysis.
EM_STATS_RETENTION=1 year

# AUDIT_LOG_RETENTION: User actions and RPC calls (login, firmware update, etc.)
#   ~100-1000 rows/day depending on usage. 90 days keeps ~50-200MB.
#   Set to '1 year' for compliance, '30 days' to save space.
AUDIT_LOG_RETENTION=90 days

# ─── mDNS Repeater (used with --with mdns) ────────────────
# Leave empty for auto-detection (recommended).
# MDNS_ON = host network interface where Shelly devices are (e.g. eth0, enp1s0)
# MDNS_TO = Docker bridge network (auto-created as br-<project>)
MDNS_ON=
MDNS_TO=
