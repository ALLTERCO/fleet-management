{
    "name": "@fleet-management/frontend",
    "private": true,
    "version": "1.9.0",
    "type": "module",
    "scripts": {
        "dev": "vite --host=0.0.0.0",
        "build": "vue-tsc && vite build",
        "build:client": "vite build --mode client",
        "build:client:strict": "vue-tsc -p tsconfig.client.json && vite build --mode client",
        "lint": "vue-tsc --noEmit && npm run check:host-api && npm run check:template-boundaries",
        "check:host-api": "node scripts/check-host-api-coverage.mjs",
        "check:template-boundaries": "node scripts/check-template-boundaries.mjs",
        "validate:customization": "node scripts/validate-customization.mjs",
        "validate:template-package": "node scripts/validate-template-package.mjs",
        "sync-images": "bash ../tools/sync-device-images.sh",
        "preview": "vite preview",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:e2e": "playwright test",
        "postinstall": "patch-package"
    },
    "engines": {
        "node": ">=24.0.0 <25.0.0"
    },
    "dependencies": {
        "@codemirror/autocomplete": "^6.20.1",
        "@codemirror/commands": "^6.10.3",
        "@codemirror/lang-html": "^6.4.11",
        "@codemirror/lang-json": "^6.0.2",
        "@codemirror/lang-markdown": "^6.5.0",
        "@codemirror/language": "^6.12.3",
        "@codemirror/state": "^6.6.0",
        "@codemirror/view": "^6.41.1",
        "@deck.gl/aggregation-layers": "^9.3.2",
        "@deck.gl/core": "^9.3.2",
        "@deck.gl/geo-layers": "^9.3.2",
        "@deck.gl/layers": "^9.3.2",
        "@deck.gl/mapbox": "^9.3.2",
        "@lezer/highlight": "^1.2.3",
        "@tiptap/pm": "^3.22.4",
        "@tiptap/starter-kit": "^3.22.4",
        "@tiptap/vue-3": "^3.22.4",
        "@types/three": "^0.184.1",
        "@vuepic/vue-datepicker": "^12.1.0",
        "@vueuse/core": "^14.3.0",
        "@vueuse/integrations": "^14.3.0",
        "axios": "^1.15.2",
        "cytoscape": "^3.33.3",
        "cytoscape-cose-bilkent": "^4.1.0",
        "dompurify": "^3.4.6",
        "echarts": "^6.0.0",
        "fuse.js": "^7.3.0",
        "maplibre-gl": "^4.7.1",
        "oidc-client-ts": "^3.5.0",
        "pinia": "^3.0.4",
        "pixi-viewport": "^6.0.3",
        "pixi.js": "^8.18.1",
        "sortablejs": "^1.15.7",
        "three": "^0.184.0",
        "vue": "^3.5.35",
        "vue-json-pretty": "^2.6.0",
        "vue-router": "^5.1.0",
        "web-vitals": "^5.2.0",
        "xstate": "^5.31.0"
    },
    "devDependencies": {
        "@playwright/test": "^1.59.1",
        "@tailwindcss/postcss": "^4.3.0",
        "@types/node": "^24.0.0",
        "@types/sortablejs": "^1.15.9",
        "@vitejs/plugin-vue": "^6.0.6",
        "@vue/compiler-dom": "^3.5.35",
        "@vue/compiler-sfc": "^3.5.35",
        "@vue/test-utils": "^2.4.10",
        "happy-dom": "^20.9.0",
        "patch-package": "^8.0.1",
        "postcss": "^8.5.10",
        "postinstall-postinstall": "^2.1.0",
        "tailwindcss": "^4.3.0",
        "typescript": "^5.9.3",
        "vite": "^7.3.2",
        "vite-plugin-pwa": "^1.2.0",
        "vitest": "^4.1.5",
        "vue-tsc": "^3.2.7"
    }
}
