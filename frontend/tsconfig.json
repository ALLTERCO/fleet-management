{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    

    /* Linting */
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": false,
    "paths": {
      "@/*": ["./src/*"],
      "@app-root": ["./src/App.vue"],
      "@router-routes": ["./src/router/routes.full.ts"],
      "@host": ["./src/shell/template-host/index.ts"],
      "@host/*": ["./src/shell/template-host/*"],
      "@template/*": ["./src/template-active/*"],
      "@template-contract": ["./src/template-contract/index.ts"],
      "@template-contract/*": ["./src/template-contract/*"],
      "@shared/*": ["./src/shared/*"],
      "@api/*": ["../backend/src/types/api/*"]
    },
    "types": []
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.tsx", "src/**/*.vue", "src/App.vue", "typed-router.d.ts", "../backend/src/types/api/**/*.ts"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
